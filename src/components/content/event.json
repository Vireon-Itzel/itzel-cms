{
  "collectionName": "components_content_events",
  "info": {
    "displayName": "event"
  },
  "options": {},
  "attributes": {
    "eventType": {
      "type": "string",
      "maxLength": 20,
      "required": true
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "title": {
      "type": "string",
      "maxLength": 100,
      "required": true
    },
    "subtitle": {
      "type": "string",
      "maxLength": 60
    },
    "locationUrlMaps": {
      "type": "string",
      "maxLength": 250
    },
    "locationLabel": {
      "type": "string",
      "maxLength": 30,
      "required": true
    },
    "startDate": {
      "type": "date"
    },
    "endDate": {
      "type": "date"
    },
    "startTime": {
      "type": "time"
    },
    "endTime": {
      "type": "time"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "titleRegistrer": {
      "type": "string",
      "default": "No te pierdas nada",
      "maxLength": 80,
      "required": false
    },
    "descriptionRegistrer": {
      "type": "string",
      "default": "Déjanos tus datos para enviarte más información sobre este evento.",
      "maxLength": 200
    },
    "instructionsRegisterSuccess": {
      "type": "string",
      "maxLength": 250
    },
    "titleRegisterSuccess": {
      "type": "string",
      "maxLength": 80
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    }
  },
  "config": {}
}
