{
  "collectionName": "components_content_interstitial_cards",
  "info": {
    "displayName": "interstitialCards"
  },
  "options": {},
  "attributes": {
    "name": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "slug": {
      "type": "string",
      "maxLength": 120,
      "required": true,
      "unique": true,
      "regex": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "description": {
      "type": "text",
      "maxLength": 500
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images"
      ]
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "SEO": {
      "type": "component",
      "component": "seo.seo",
      "repeatable": false
    },
    "productos": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::product.product"
    }
  },
  "config": {}
}
