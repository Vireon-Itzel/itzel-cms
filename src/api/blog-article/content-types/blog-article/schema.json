{
  "kind": "collectionType",
  "collectionName": "blog_articles",
  "info": {
    "singularName": "blog-article",
    "pluralName": "blog-articles",
    "displayName": "Articulos Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "maxLength": 250,
      "required": true
    },
    "slug": {
      "type": "uid"
    },
    "shortDescription": {
      "type": "string",
      "maxLength": 255,
      "required": true
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "images",
        "files"
      ]
    },
    "iframeHeroVideoYoutube": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": [
        "files",
        "videos"
      ]
    },
    "isActive": {
      "type": "boolean",
      "required": true,
      "default": true
    },
    "content": {
      "type": "dynamiczone",
      "components": [
        "blog.article-quote",
        "blog.article-image",
        "blog.article-content"
      ]
    },
    "subcategory": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::subcategory.subcategory",
      "inversedBy": "articles"
    },
    "writer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::writer.writer",
      "inversedBy": "articles"
    }
  }
}
